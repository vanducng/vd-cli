---
/* Replaces Starlight's social icons with a prominent GitHub link + live star/fork counts.
   Counts are fetched once per build (memoized) with a graceful icon-only fallback. */
const REPO = 'vanducng/vd-cli';

const g = globalThis as any;
g.__ghStats ??= fetch(`https://api.github.com/repos/${REPO}`, {
  headers: { 'User-Agent': 'starlight-docs-build', Accept: 'application/vnd.github+json' },
})
  .then((r) => (r.ok ? r.json() : null))
  .then((d) => (d ? { stars: d.stargazers_count as number, forks: d.forks_count as number } : null))
  .catch(() => null);

const stats: { stars: number; forks: number } | null = await g.__ghStats;
const fmt = (n: number) =>
  n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : String(n);
---

<a class="gh-link" href={`https://github.com/${REPO}`} target="_blank" rel="noopener noreferrer" aria-label="View this repository on GitHub">
  <svg class="gh-mark" viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
  </svg>
  <span class="gh-text">GitHub</span>
  {stats && (
    <span class="gh-stats">
      <span class="gh-stat" title={`${stats.stars} stars`}>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 18l-5.8 3 1.1-6.5L2.6 9.3l6.5-.9z"/></svg>
        {fmt(stats.stars)}
      </span>
      <span class="gh-stat" title={`${stats.forks} forks`}>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="5" r="2.4"/><circle cx="18" cy="5" r="2.4"/><circle cx="12" cy="19" r="2.4"/><path d="M6 7.4v2.2a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V7.4M12 12.6v4"/></svg>
        {fmt(stats.forks)}
      </span>
    </span>
  )}
</a>

<style>
  .gh-link {
    display: inline-flex;
    align-items: center;
    box-sizing: border-box;
    height: 2.5rem;
    gap: 0.45rem;
    padding: 0 0.7rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background-color: var(--sl-color-bg-nav);
    color: var(--sl-color-text);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }
  .gh-link:hover {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-4);
  }
  .gh-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }
  .gh-stats {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding-left: 0.55rem;
    border-left: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
  }
  .gh-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
  }
  .gh-stat svg { opacity: 0.85; }
  @media (max-width: 50rem) {
    .gh-text { display: none; }
  }
</style>
